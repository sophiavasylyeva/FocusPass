<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/blocking_background"
    android:padding="32dp">

    <!-- App Icon -->
    <ImageView
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:layout_marginBottom="24dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="FocusPass Logo" />

    <!-- Title -->
    <TextView
        android:id="@+id/titleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="📚 Complete Educational Tasks First!"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/blocking_title"
        android:textAlignment="center"
        android:layout_marginBottom="16dp" />

    <!-- Message -->
    <TextView
        android:id="@+id/messageText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="You have educational tasks to complete before accessing this app."
        android:textSize="16sp"
        android:textColor="@color/blocking_text"
        android:textAlignment="center"
        android:layout_marginBottom="16dp" />

    <!-- Earnable Time Info -->
    <TextView
        android:id="@+id/earnableTimeText"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Complete tasks to earn 15 minutes of screen time!"
        android:textSize="14sp"
        android:textColor="@color/blocking_success"
        android:textAlignment="center"
        android:textStyle="bold"
        android:layout_marginBottom="32dp"
        android:background="@drawable/rounded_background_success"
        android:padding="12dp" />

    <!-- Action Button -->
    <Button
        android:id="@+id/actionButton"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:text="📚 Complete Tasks Now"
        android:textSize="16sp"
        android:textStyle="bold"
        android:textColor="@color/white"
        android:background="@drawable/rounded_button_primary"
        android:layout_marginBottom="16dp" />

    <!-- Later Button -->
    <Button
        android:id="@+id/laterButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="⏰ Remind Me Later"
        android:textSize="14sp"
        android:textColor="@color/blocking_secondary"
        android:background="@drawable/rounded_button_secondary"
        style="?android:attr/borderlessButtonStyle" />

</LinearLayout>
